# ─────────────────────────────────────────────────────────────────
#  VARIABLES DE ENTORNO — Indians Sistema Textil (backIndians)
#  Copiar este archivo a .env para desarrollo local.
#  En Railway configurar cada variable en el dashboard (no subir .env).
# ─────────────────────────────────────────────────────────────────

# Servidor
PORT=3000
# En Railway: NODE_ENV=production  (configurar en Variables del proyecto)
NODE_ENV=development

# ── Base de datos MySQL ───────────────────────────────────────────
# En Railway: usar los datos del plugin MySQL de Railway
#   DB_HOST    → desde Railway MySQL → Connect → Host
#   DB_PORT    → desde Railway MySQL → Connect → Port
#   DB_NAME    → desde Railway MySQL → Connect → Database
#   DB_USER    → desde Railway MySQL → Connect → Username
#   DB_PASSWORD → desde Railway MySQL → Connect → Password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=textil_db
DB_USER=root
DB_PASSWORD=secret

# ── JWT — IMPORTANTE: usar valores únicos y seguros en producción ─
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERAR_VALOR_UNICO_MINIMO_64_BYTES
JWT_REFRESH_SECRET=GENERAR_VALOR_UNICO_MINIMO_64_BYTES_DIFERENTE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Frontend (CORS) ───────────────────────────────────────────────
# En Railway: URL del deploy del frontend (ej: https://indians-front.vercel.app)
FRONTEND_URL=http://localhost:5173

# ── SMTP (recuperación de contraseña) — opcional ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_de_google
SMTP_FROM="Sistema Textil <tu_email@gmail.com>"

# ── Cloudflare Turnstile (CAPTCHA anti-bot en el registro de compradores) ──
# Crear un sitio gratis en https://dash.cloudflare.com/?to=/:account/turnstile
# Copiar el "Secret Key" acá y el "Site Key" en frontIndians/.env (VITE_TURNSTILE_SITE_KEY).
# Si se deja vacío, la verificación se OMITE (modo graceful, registro sin CAPTCHA).
TURNSTILE_SECRET_KEY=

# ── Flags de seguridad (testing) ─────────────────────────────────
# RATE_LIMIT_DISABLED=1 desactiva rate-limit y CAPTCHA (usar SOLO en tests de carga locales).
# RATE_LIMIT_DISABLED=

# ── MercadoPago ───────────────────────────────────────────────────
# Obtener en https://www.mercadopago.com.ar/developers/panel/credentials
# TEST credentials para desarrollo, PRODUCTION para producción
# NUNCA poner credenciales reales acá: este archivo es de ejemplo y se versiona.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Google OAuth (registro e inicio de sesión con Google en la tienda) ────────
# Obtener en https://console.cloud.google.com → APIs y servicios → Credenciales
#   1. Crear proyecto → Pantalla de consentimiento (tipo Externo)
#   2. Crear credencial → OAuth 2.0 → Aplicación web
#   3. Agregar origen autorizado: http://localhost:5173 (dev) y el dominio de producción
#   4. Copiar el "ID de cliente" (termina en .apps.googleusercontent.com)
# Uso gratuito y sin límite de solicitudes para autenticación estándar.
# Si se deja vacío, el botón "Continuar con Google" no aparece en la tienda.
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
