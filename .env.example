# ─────────────────────────────────────────────────────────────────
#  VARIABLES DE ENTORNO — Indians Sistema Textil (backIndians)
#  Copiar este archivo a .env para desarrollo local.
#  En Railway configurar cada variable en el dashboard (no subir .env).
# ─────────────────────────────────────────────────────────────────

# Servidor
PORT=3000
# En Railway: NODE_ENV=production  (configurar en Variables del proyecto)
NODE_ENV=development

# ── Base de datos MySQL ───────────────────────────────────────────
# En Railway: usar los datos del plugin MySQL de Railway
#   DB_HOST    → desde Railway MySQL → Connect → Host
#   DB_PORT    → desde Railway MySQL → Connect → Port
#   DB_NAME    → desde Railway MySQL → Connect → Database
#   DB_USER    → desde Railway MySQL → Connect → Username
#   DB_PASSWORD → desde Railway MySQL → Connect → Password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=textil_db
DB_USER=root
DB_PASSWORD=secret

# ── JWT — IMPORTANTE: usar valores únicos y seguros en producción ─
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERAR_VALOR_UNICO_MINIMO_64_BYTES
JWT_REFRESH_SECRET=GENERAR_VALOR_UNICO_MINIMO_64_BYTES_DIFERENTE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Frontend (CORS) ───────────────────────────────────────────────
# En Railway: URL del deploy del frontend (ej: https://indians-front.vercel.app)
FRONTEND_URL=http://localhost:5173

# ── SMTP (recuperación de contraseña) — opcional ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password_de_google
SMTP_FROM="Sistema Textil <tu_email@gmail.com>"
